# Copy relevant lines to the matching local env file and fill in local values.
# Do not commit .env.cloudflare or .env.openrouter.
CLOUDFLARE_API_TOKEN=replace-with-token

# Optional Cloudflare Radar overrides
CLOUDFLARE_RADAR_DATE_RANGE=7d
CLOUDFLARE_RADAR_TIMEOUT_SECONDS=8
CLOUDFLARE_RADAR_LIMIT=10

# Optional Prime Observer ASN-scoped Internet Conditions target
PRIME_OBSERVER_INTERNET_ASN=22773
PRIME_OBSERVER_INTERNET_PROVIDER_LABEL=Cox

# Optional OpenRouter configuration for Operator Assistant
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3.5-flash
